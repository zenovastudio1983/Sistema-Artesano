# ============================================================
# Variables de entorno para Railway
# Copia estas variables en: Railway Dashboard → Service → Variables
# ============================================================

# --- Aplicación ---
APP_NAME="Artisan ERP"
APP_ENV=production
APP_KEY=                        # Genera con: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=                        # Railway lo pone automático, ej: https://sistema-artesano.up.railway.app
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# --- Base de datos (Railway Postgres) ---
# Usa la referencia a la variable DATABASE_URL del plugin Postgres:
DATABASE_URL=${{Postgres.DATABASE_URL}}
DB_CONNECTION=pgsql

# --- Cache / Sesiones / Colas (sin Redis) ---
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=error

# --- Email (opcional) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="erp@artisanal.local"
MAIL_FROM_NAME="Artisan ERP"

# --- ERP ---
ERP_CURRENCY=ARS
ERP_CURRENCY_SYMBOL=$
ERP_DECIMAL_PLACES=2
ERP_TAX_RATE=21
ERP_COMPANY_NAME="Mi Taller Artesanal"
ERP_COST_METHOD=average
ERP_LOW_STOCK_ALERT_DAYS=7

BCRYPT_ROUNDS=12
TELESCOPE_ENABLED=false
