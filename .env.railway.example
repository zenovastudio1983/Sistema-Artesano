# ============================================================
# Variables de entorno para Railway
# Copia estas variables en: Railway Dashboard → Service → Variables
# ============================================================

# --- Aplicación ---
APP_NAME="Artisan ERP"
APP_ENV=production
APP_KEY=                        # Genera con: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=America/Lima
APP_URL=                        # Railway lo pone automático, ej: https://artisan-erp.up.railway.app
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# --- Base de datos (Railway Postgres) ---
# Railway las inyecta automáticamente si conectas el plugin de Postgres:
DB_CONNECTION=pgsql
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_DATABASE=${{Postgres.PGDATABASE}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# --- Redis (Railway Redis) ---
# Railway las inyecta automáticamente si conectas el plugin de Redis:
REDIS_CLIENT=predis
REDIS_HOST=${{Redis.REDIS_HOST}}
REDIS_PORT=${{Redis.REDIS_PORT}}
REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}
REDIS_DB=0
REDIS_CACHE_DB=1

# --- Cache / Sesiones / Colas ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=error

# --- Email (opcional, configura si quieres emails) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="erp@artisanal.local"
MAIL_FROM_NAME="Artisan ERP"

# --- ERP ---
ERP_CURRENCY=PEN
ERP_CURRENCY_SYMBOL=S/.
ERP_DECIMAL_PLACES=2
ERP_TAX_RATE=18
ERP_COMPANY_NAME="Mi Taller Artesanal"
ERP_COST_METHOD=average
ERP_LOW_STOCK_ALERT_DAYS=7

BCRYPT_ROUNDS=12
TELESCOPE_ENABLED=false
